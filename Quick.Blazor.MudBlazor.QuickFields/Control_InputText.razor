@using MudBlazor
@using Quick.Fields
@using global::MudBlazor

<InputBase Field="@Field">
    <MudTextField @bind-Value="Field.Value" Label="@Field.Name" HelperText="@Field.Description"
                  ReadOnly="@ControlUtils.GetInputReadOnly(Field)" AdornmentColor="ControlUtils.GetColor(Field)"
                  Variant="ControlUtils.GetVariant(Field)"
                  Required="@(Field.Input_AllowBlank==null?false:Field.Input_AllowBlank.Value)" />
</InputBase>

@code
{
    [Parameter]
    public FieldForGet Field { get; set; }
}